# PocketBase API (required in production)
POCKETBASE_URL=http://127.0.0.1:8090

# Session signing (required in production; use a long random string)
SESSION_SECRET=change-me-in-production

# VPN-only stack (docker-compose.vpn.yml): WireGuard Easy default subnet
# VPN_SOURCERANGE=10.8.0.0/24
# DOMAIN=gestionale.local
